FROM postgres:18.4-trixie

# mkdir /app
RUN mkdir /app

WORKDIR /app

RUN apt-get update \
    && apt-get upgrade -y \
    && apt-get install -y postgresql-18-cron supervisor curl libatomic1 git

# Install Node.js
RUN curl -fsSL https://deb.nodesource.com/setup_24.x | bash - \
    && apt install -y nodejs \
    && npm install -g corepack \
    && corepack enable pnpm \
    && pnpm -v

# no-cache after new commit
ARG CACHEBUST=-1
RUN echo building for commit "$CACHEBUST"
# Clone the repository
RUN git clone https://github.com/lijunjie2232/mylawer.git /app \
    && cd /app \
    && git config --global url."https://github.com/".insteadOf "git@github.com:" \
    && git submodule update --init --recursive

RUN cp /app/scripts/docker-entrypoint_hook.sh /usr/local/bin/docker-entrypoint.sh

COPY ./third/legal-mcp/config.yaml /app/third/legal-mcp/config.yaml

RUN cd frontend \
    && pnpm i \
    && pnpm build \
    && cd .. \
    && cd third/legal-mcp/js_legal \
    && pnpm install \
    && pnpm build \
    && cd ../../.. \
    && cd third/webmcp \
    && pnpm install \
    && pnpm binary:sync \
    && cd ../.. \
    && pnpm i \
    && pnpm db:generate \
    && pnpm build

RUN pnpm store prune

# supervisor
RUN cp /app/scripts/app.sh /app/app.sh \
    && cp /app/scripts/supervisord.conf /etc/supervisor/conf.d/supervisord.conf

RUN apt-get clean && rm -rf /var/lib/apt/lists/* && rm -rf /tmp/* /var/tmp/*

EXPOSE 3000

CMD ["/usr/bin/supervisord", "-c", "/etc/supervisor/conf.d/supervisord.conf"]
