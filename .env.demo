# ============================================
# Law Assistant Environment Configuration
# ============================================
# Copy this file to .env and customize the values
# 
# IMPORTANT: PostgreSQL password configuration
# - POSTGRES_PASSWORD is used for database initialization
# - Make sure to set a strong password in production
# ============================================

# ============================================
# Unified LLM Configuration System
# ============================================
# Model provider selection (openai | anthropic | ollama | ...)
LLM_MODEL_PROVIDER=openai

# Unified model configuration
LLM_MODEL_NAME=
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_MAX_TOKENS=
LLM_TEMPERATURE=0.3

# Unified API key (shared by all providers)
LLM_API_KEY=

USE_FREE_MODEL=true
FREE_MODEL_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_MODEL=nvidia/nemotron-3-nano-30b-a3b:free

# ============================================
# Application Configuration
# ============================================
NODE_ENV=production
PORT=3000

# Log configuration
LOG_LEVEL=warn

# ============================================
# LINE Bot Configuration
# ============================================
#LINE_CHANNEL_SECRET=your_line_channel_secret_here
#LINE_ACCESS_TOKEN=your_line_access_token_here


#ALLOWED_MCP_TOOLS=

ALLOWED_MCP_TOOLS=webmcp_deep_search,webmcp_parse_url,webmcp_get_available_engines,legal-mcp_search_laws


# ============================================
# Database Configuration (PostgreSQL)
# ============================================
# PostgreSQL root password (for database initialization)
# ⚠️ IMPORTANT: Change this to a strong password in production!
POSTGRES_PASSWORD="las_passwd"

# PostgreSQL user and database name (optional, defaults shown)
POSTGRES_USER="las_user"
POSTGRES_DB="las"

# PostgreSQL connection URL for application
# For single container: use localhost
# For split configuration: use postgres (Docker service name)
#DATABASE_URL="postgresql://las_user:las_passwd@localhost:5432/las?schema=public"

# ============================================
# JWT & Authentication Configuration
# ============================================
# JWT secret key (use a strong random string in production)
# openssl rand -base64 32
JWT_SECRET="yMbDamh25LsOdqEb8sPD+T1JoxUJ9bOgc1ftGFSP8Eo="

# Token expiration time in seconds (default: 24 hours = 86400)
JWT_EXPIRES_IN=86400

# Session token expiration for client-side storage (default: 7 days = 604800)
SESSION_TOKEN_EXPIRES_IN=604800

# Default admin credentials (change after first login!)
DEFAULT_ADMIN_EMAIL="admin@example.com"
DEFAULT_ADMIN_PASSWORD="Admin123!@#"

# docker script env
RUN_MIGRATIONS=true
INIT_ADMIN=true
