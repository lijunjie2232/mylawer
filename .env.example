# ============================================
# 统一的 LLM 配置系统
# 通过 LLM_MODEL_PROVIDER 区分不同提供商
# ============================================

# 模型提供商选择 (openai | anthropic)
LLM_MODEL_PROVIDER=openai

# 统一的模型配置
LLM_MODEL_NAME=
LLM_BASE_URL=https://api.openai.com/v1
# LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=0.3

# 统一的 API 密钥（所有提供商共用）
LLM_API_KEY=your_api_key_here

USE_FREE_MODEL=true
FREE_MODEL_BASE_URL=https://openrouter.ai/api/v1
# 默认使用的模型 ID (例如：google/gemini-2.0-flash-001)
DEFAULT_MODEL=nvidia/nemotron-3-nano-30b-a3b:free

# 允许使用的模型列表（逗号或分号分隔），留空表示允许所有模型
# 示例：ALLOW_MODELS=gpt-4o-mini,gpt-4o,claude-3-haiku
# 示例：ALLOW_MODELS=gpt-4o-mini;gpt-4o;claude-3-haiku
ALLOW_MODELS=

# 允许使用的MCP工具列表（逗号或分号分隔），留空表示允许所有工具
# 格式：serverName_toolName
# 
# Available webmcp tools:
#   - webmcp_search: Search for a keyword on a specified search engine
#   - webmcp_search_multiple: Search for a keyword on multiple search engines
#   - webmcp_deep_search: Perform deep search by searching and parsing result pages
#   - webmcp_get_available_engines: Get list of available search engines
#   - webmcp_set_language: Set the language/locale for search results
#   - webmcp_parse_url: Parse a web page URL and extract its content
#
# Available legal-mcp tools:
#   - legal-mcp_search_laws: Search for Japanese laws and regulations
#   - legal-mcp_get_law_by_id: Retrieve full details of a specific law by ID
#   - legal-mcp_get_cluster_status: Get Elasticsearch cluster status
#   - legal-mcp_get_index_state: Get detailed statistics of the legal documents index
#   - legal-mcp_get_raw_json_by_id: Retrieve complete raw JSON data for a law by ID
#
# Examples:
# ALLOWED_MCP_TOOLS=webmcp_search,legal-mcp_search_laws
# ALLOWED_MCP_TOOLS=webmcp_search;webmcp_parse_url;legal-mcp_search_laws
ALLOWED_MCP_TOOLS=webmcp_deep_search,webmcp_parse_url,webmcp_get_available_engines,legal-mcp_search_laws,legal-mcp_get_law_by_id,legal-mcp_get_cluster_status,legal-mcp_get_index_state,legal-mcp_get_raw_json_by_id


# アプリケーション設定
NODE_ENV=development
PORT=3000

# ログ設定
LOG_LEVEL=info

# LINE Bot 設定
LINE_CHANNEL_SECRET=your_line_channel_secret_here
LINE_ACCESS_TOKEN=your_line_access_token_here


# search api key
TAVILY_API_KEY=tvly-dev-xxxx-xxxxxxxx
JINA_API_KEY=xxxx

# ============================================
# Database Configuration (PostgreSQL)
# ============================================
# SQL Database type (postgresql, mysql, sqlite, etc. - default is postgresql)
DB_TYPE=postgresql

# PostgreSQL connection URL for application
# IMPORTANT: Change the password in production!
DATABASE_URL="postgresql://law_user:SecureP@ssw0rd2024!@localhost:5432/law_assistant?schema=public"

# PostgreSQL root password (for database initialization)
# IMPORTANT: Use a strong random password in production!
POSTGRES_PASSWORD="SecureP@ssw0rd2024!"

# PostgreSQL user and database name (optional, defaults shown)
POSTGRES_USER="law_user"
POSTGRES_DB="law_assistant"

# ============================================
# JWT & Authentication Configuration
# ============================================
# JWT secret key (use a strong random string in production)
JWT_SECRET="your_jwt_secret_key_here_change_in_production"

# Token expiration time in seconds (default: 24 hours = 86400)
JWT_EXPIRES_IN=86400

# Session token expiration for client-side storage (default: 7 days = 604800)
SESSION_TOKEN_EXPIRES_IN=604800

# Default admin credentials (change after first login!)
DEFAULT_ADMIN_EMAIL="admin@example.com"
DEFAULT_ADMIN_PASSWORD="Admin123!@#"

# Docker Script Environment
RUN_MIGRATIONS=true
INIT_ADMIN=true