  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:server": "node dist/index.js --server",
    "dev": "concurrently 'tsx watch src/index.ts --server' 'cd frontend && pnpm build --watch'",
    "dev:server": "tsx watch src/index.ts --server",
    "cli": "ts-node src/index.ts",
    "server": "ts-node src/index.ts --server",
    "frontend:dev": "cd frontend && pnpm dev",
    "frontend:build": "cd frontend && pnpm build",
    "dev:full": "concurrently \"pnpm dev:server\" \"pnpm frontend:dev\"",
    "db:init-admin": "tsx scripts/init-admin.ts",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate"
  },
